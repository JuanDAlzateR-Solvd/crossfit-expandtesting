# Environment variables consumed by src/config/env.ts
# Copy to `.env` and adjust as needed. The defaults below are the PUBLICLY
# DOCUMENTED practice values from practice.expandtesting.com — they are NOT
# secrets. Never commit real credentials.

# System under test
BASE_URL=https://practice.expandtesting.com

# Valid login credentials (public practice values)
TEST_USERNAME=practice
TEST_PASSWORD=SuperSecretPassword!

# Optional — OTP login flow (public practice values)
# OTP_EMAIL=practice@expandtesting.com
# OTP_CODE=214365
